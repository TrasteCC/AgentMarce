# ============================================================
# AgentMarce - Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file to GitHub.
# ============================================================

# ------------------------------------------------------------
# LOCAL LLM (Ollama)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5:1.5b
# Alternative if you need more capacity: llama3.2:3b-instruct-q4_K_M

# ------------------------------------------------------------
# CLOUD LLM - Groq (log analysis, heavy tasks)
# Get your key at: https://console.groq.com
# ------------------------------------------------------------
GROQ_API_KEY=gsk_your_key_here

# ------------------------------------------------------------
# CLOUD LLM - OpenRouter (fallback: Claude/GPT/Gemini)
# Get your key at: https://openrouter.ai
# ------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-your_key_here
OPENROUTER_MODEL=google/gemini-flash-1.5

# ------------------------------------------------------------
# COMMUNICATION INTERFACES
# ------------------------------------------------------------

# Telegram - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxyz

# Slack - Get at https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# ------------------------------------------------------------
# INFRASTRUCTURE - Home Assistant
# Token: HA → Profile → Long-Lived Access Tokens
# ------------------------------------------------------------
HOME_ASSISTANT_URL=http://192.168.1.X:8123
HOME_ASSISTANT_TOKEN=eyJhbGciOiJIUzI1NiIsInR...

# ------------------------------------------------------------
# INFRASTRUCTURE - Proxmox
# Use an API Token with the PVEAuditor role (read-only).
# Format: user@realm!token_name
# ------------------------------------------------------------
PROXMOX_HOST=192.168.1.X
PROXMOX_API_TOKEN_ID=root@pam!agent-readonly
PROXMOX_API_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ------------------------------------------------------------
# INFRASTRUCTURE - Unraid SSH
# Use a restricted user (agent-runner), not root.
# ------------------------------------------------------------
UNRAID_HOST=192.168.1.X
UNRAID_SSH_USER=agent-runner
UNRAID_SSH_KEY_PATH=/home/agentuser/.ssh/id_rsa_unraid

# ------------------------------------------------------------
# GOOGLE APIs - OAuth2
# Get at: https://console.cloud.google.com
# Project: AgentMarce, type: Desktop application
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
# File paths (do not change if you follow the guide)
GOOGLE_CREDENTIALS_PATH=/home/agentuser/agent-services/antigravity-agent/config/google_credentials.json
GOOGLE_TOKEN_PATH=/home/agentuser/agent-services/antigravity-agent/config/google_token.json
