# ============================================================
# AgentMarce - Variables de Entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA subas el archivo .env a GitHub
# ============================================================

# ------------------------------------------------------------
# LLM LOCAL (Ollama)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5:1.5b
# Alternativa si necesitas mas capacidad: llama3.2:3b-instruct-q4_K_M

# ------------------------------------------------------------
# LLM CLOUD - Groq (analisis de logs, tareas pesadas)
# Obtener en: https://console.groq.com
# ------------------------------------------------------------
GROQ_API_KEY=gsk_tu_clave_aqui

# ------------------------------------------------------------
# LLM CLOUD - OpenRouter (fallback, Claude/GPT/Gemini)
# Obtener en: https://openrouter.ai
# ------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-tu_clave_aqui
OPENROUTER_MODEL=google/gemini-flash-1.5

# ------------------------------------------------------------
# INTERFACES DE COMUNICACION
# ------------------------------------------------------------

# Telegram - Obtener con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxyz

# Slack - Obtener en https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-tu-slack-bot-token
SLACK_SIGNING_SECRET=tu_slack_signing_secret

# ------------------------------------------------------------
# INFRAESTRUCTURA - Home Assistant
# Token: HA → Perfil → Long-Lived Access Tokens
# ------------------------------------------------------------
HOME_ASSISTANT_URL=http://192.168.1.X:8123
HOME_ASSISTANT_TOKEN=eyJhbGciOiJIUzI1NiIsInR...

# ------------------------------------------------------------
# INFRAESTRUCTURA - Proxmox
# Usar API Token con rol PVEAuditor (solo lectura)
# Formato: usuario@realm!nombre_token
# ------------------------------------------------------------
PROXMOX_HOST=192.168.1.X
PROXMOX_API_TOKEN_ID=root@pam!agent-readonly
PROXMOX_API_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ------------------------------------------------------------
# INFRAESTRUCTURA - Unraid SSH
# Usar usuario restringido (agent-runner), no root
# ------------------------------------------------------------
UNRAID_HOST=192.168.1.X
UNRAID_SSH_USER=agent-runner
UNRAID_SSH_KEY_PATH=/home/agentuser/.ssh/id_rsa_unraid

# ------------------------------------------------------------
# GOOGLE APIs - OAuth2
# Obtener en: https://console.cloud.google.com
# Proyecto: AgentMarce, tipo: Aplicacion de escritorio
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu_client_secret
# Rutas de archivos (no cambiar si sigues la guia)
GOOGLE_CREDENTIALS_PATH=/home/agentuser/agent-services/antigravity-agent/config/google_credentials.json
GOOGLE_TOKEN_PATH=/home/agentuser/agent-services/antigravity-agent/config/google_token.json
