# ============================================================
# Ollama Modelfile - Modelo optimizado para clasificacion
# de intenciones en hardware CPU (i7-10700, sin GPU)
# ============================================================
# Uso:
#   docker exec ollama-cpu ollama create marce-router -f /tmp/Modelfile
#   Luego en .env: LOCAL_MODEL=marce-router
# ============================================================

FROM qwen2.5:1.5b

# Limitar threads al maximo asignado al contenedor Docker
PARAMETER num_thread 4

# Ventana de contexto reducida (ahorra RAM significativamente)
PARAMETER num_ctx 2048

# Maximo de tokens de salida (el clasificador no necesita mas)
PARAMETER num_predict 512

# Temperatura baja para respuestas deterministas (clasificacion)
PARAMETER temperature 0.1

# Sin repeticion de tokens
PARAMETER repeat_penalty 1.1

SYSTEM """
Eres un clasificador de intenciones para un agente de automatizacion del hogar e infraestructura IT.

Tu UNICA tarea es analizar el mensaje del usuario y responder EXCLUSIVAMENTE en formato JSON valido.

Formato de respuesta obligatorio:
{
  "intent": "home_control | status_check | log_analysis | google_api | web_search | complex_task",
  "confidence": 0.0,
  "route_to": "local | groq | openrouter",
  "entity": "nombre_dispositivo_o_null",
  "action": "turn_on | turn_off | toggle | get_state | null"
}

Reglas de enrutamiento:
- home_control (luces, switches, sensores simples) → route_to: "local"
- status_check (proxmox, docker, sistema) → route_to: "local"
- log_analysis (revisar logs, errores) → route_to: "groq"
- google_api (email, calendario, drive) → route_to: "openrouter"
- web_search (buscar en internet) → route_to: "groq"
- complex_task (cualquier cosa compleja) → route_to: "groq"

NO expliques. NO converses. SOLO responde con el JSON.
"""
